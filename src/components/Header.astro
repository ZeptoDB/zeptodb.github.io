---
import config from 'virtual:starlight/user-config';
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';

const shouldRenderSearch =
	config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';

const repo = 'zeptodb/zeptodb';
let stars = '';
try {
  const res = await fetch(`https://api.github.com/repos/${repo}`);
  if (res.ok) {
    const d = await res.json();
    const s = d.stargazers_count ?? 0;
    stars = s >= 1000 ? `${(s / 1000).toFixed(1)}k` : String(s);
  }
} catch {}

const currentPath = Astro.url.pathname;

const navLinks = [
  {
    label: 'Product',
    href: '/features/',
    children: [
      { label: 'Features', href: '/features/' },
      { label: 'Benchmarks', href: '/benchmarks/' },
      { label: 'Security', href: '/security/' },
      { label: 'Integrations', href: '/integrations/' },
    ],
  },
  {
    label: 'Use Cases',
    href: '/use-cases/trading/',
    children: [
      { label: 'Trading & Finance', href: '/use-cases/trading/' },
      { label: 'Physical AI & Robotics', href: '/use-cases/robotics/' },
      { label: 'Smart Factory & IoT', href: '/use-cases/iot/' },
      { label: 'Autonomous Vehicles', href: '/use-cases/autonomous-vehicles/' },
    ],
  },
  {
    label: 'Compare',
    href: '/compare/vs-kdb/',
    children: [
      { label: 'vs kdb+', href: '/compare/vs-kdb/' },
      { label: 'vs ClickHouse', href: '/compare/vs-clickhouse/' },
      { label: 'vs InfluxDB', href: '/compare/vs-influxdb/' },
      { label: 'vs TimescaleDB', href: '/compare/vs-timescaledb/' },
    ],
  },
  { label: 'Docs', href: '/getting-started/quick_start/' },
  { label: 'Pricing', href: '/pricing/' },
  { label: 'Blog', href: '/blog/' },
];

function isActive(href: string) {
  return currentPath.startsWith(href.replace(/\/$/, ''));
}
---

<div class="header">
  <div class="title-wrapper sl-flex">
    <SiteTitle />
  </div>

  <nav class="top-nav sl-hidden md:sl-flex print:hidden">
    {navLinks.map((link) => (
      <div class:list={['nav-item', { 'has-dropdown': link.children }]}>
        <a
          href={link.href}
          class:list={['nav-link', { active: isActive(link.href) }]}
        >
          {link.label}
          {link.children && (
            <svg class="chevron" viewBox="0 0 12 12" width="10" height="10" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 4.5L6 7.5L9 4.5" />
            </svg>
          )}
        </a>
        {link.children && (
          <div class="dropdown">
            {link.children.map((child) => (
              <a href={child.href} class:list={['dropdown-link', { active: isActive(child.href) }]}>
                {child.label}
              </a>
            ))}
          </div>
        )}
      </div>
    ))}
  </nav>

  <div class="sl-flex print:hidden right-group">
    {shouldRenderSearch && <Search />}
    <div class="sl-hidden md:sl-flex right-icons">
      <div class="sl-flex social-icons">
        <SocialIcons />
        {stars && (
          <a class="gh-stat" href={`https://github.com/${repo}/stargazers`} target="_blank" rel="noopener" title="Stars">
            <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25z"/></svg>
            <span>{stars}</span>
          </a>
        )}
      </div>
      <ThemeSelect />
      <LanguageSelect />
    </div>
  </div>
</div>

<style>
  @layer starlight.core {
    .header {
      display: flex;
      gap: var(--sl-nav-gap);
      justify-content: space-between;
      align-items: center;
      height: 100%;
    }
    .title-wrapper {
      overflow: clip;
      padding: 0.25rem;
      margin: -0.25rem;
      min-width: 0;
      flex-shrink: 0;
    }
    .right-group,
    .right-icons,
    .social-icons {
      gap: 1rem;
      align-items: center;
    }
    .social-icons::after {
      content: '';
      height: 2rem;
      border-inline-end: 1px solid var(--sl-color-gray-5);
    }
    @media (min-width: 50rem) {
      :global(:root[data-has-sidebar]) {
        --__sidebar-pad: calc(2 * var(--sl-nav-pad-x));
      }
      :global(:root:not([data-has-toc])) {
        --__toc-width: 0rem;
      }
      .header {
        display: flex;
      }
    }
  }

  /* Top nav */
  .top-nav {
    display: flex;
    align-items: center;
    gap: 0;
    flex: 1;
    justify-content: center;
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    padding: 0.4rem 0.7rem;
    font-size: var(--sl-text-sm);
    font-weight: 500;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    border-radius: 0.375rem;
    transition: color 0.15s, background-color 0.15s;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--sl-color-white);
    background-color: var(--sl-color-gray-5);
  }

  .nav-link.active {
    color: var(--sl-color-accent);
  }

  .chevron {
    transition: transform 0.15s;
    flex-shrink: 0;
  }

  /* Dropdown */
  .dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 12rem;
    padding: 0.4rem;
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
    z-index: 100;
  }

  .nav-item.has-dropdown:hover .dropdown {
    display: flex;
    flex-direction: column;
  }

  .nav-item.has-dropdown:hover .chevron {
    transform: rotate(180deg);
  }

  .dropdown-link {
    display: block;
    padding: 0.45rem 0.75rem;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-2);
    text-decoration: none;
    border-radius: 0.375rem;
    transition: color 0.15s, background-color 0.15s;
  }

  .dropdown-link:hover {
    color: var(--sl-color-white);
    background-color: var(--sl-color-gray-5);
  }

  .dropdown-link.active {
    color: var(--sl-color-accent);
  }

  /* GitHub stat */
  .gh-stat {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: var(--sl-text-xs, 0.75rem);
    font-weight: 500;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    font-variant-numeric: tabular-nums;
    transition: color 0.15s;
  }
  .gh-stat:hover {
    color: var(--sl-color-accent);
  }
  .gh-stat svg {
    flex-shrink: 0;
  }
</style>

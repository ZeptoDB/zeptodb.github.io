---
import config from 'virtual:starlight/user-config';
import LanguageSelect from '@astrojs/starlight/components/LanguageSelect.astro';
import Search from '@astrojs/starlight/components/Search.astro';
import SiteTitle from '@astrojs/starlight/components/SiteTitle.astro';
import SocialIcons from '@astrojs/starlight/components/SocialIcons.astro';
import ThemeSelect from '@astrojs/starlight/components/ThemeSelect.astro';

const shouldRenderSearch =
	config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';

const currentPath = Astro.url.pathname;

const navLinks = [
  {
    label: 'Product',
    href: '/features/',
    children: [
      { label: 'Product Overview', href: '/features/' },
      { label: 'Action-Outcome Memory', href: '/use-cases/action-outcome-memory/' },
      { label: 'Physical AI & Robotics', href: '/use-cases/robotics/' },
      { label: 'Agent Memory', href: '/use-cases/agent-memory/' },
      { label: 'Integrations', href: '/integrations/' },
      { label: 'Benchmarks', href: '/benchmarks/' },
      { label: 'Security', href: '/security/' },
      { label: 'Agent Memory vs Vector DBs', href: '/compare/agent-memory-vs-vector-databases/' },
      { label: 'Database Comparisons', href: '/compare/vs-kdb/' },
    ],
  },
  { label: 'Experiments', href: '/experiments/' },
  {
    label: 'Docs',
    href: '/docs/',
    children: [
      { label: 'Docs Home', href: '/docs/' },
      { label: 'Quick Start', href: '/getting-started/quick_start/' },
      { label: 'ROS 2 Setup', href: '/operations/ros2_setup/' },
      { label: 'HTTP API', href: '/api/http_reference/' },
      { label: 'Python API', href: '/api/python_reference/' },
      { label: 'Deployment', href: '/deployment/production_deployment/' },
    ],
  },
  { label: 'Blog', href: '/blog/' },
  { label: 'Community', href: '/community/' },
];

function isActive(href: string) {
  return currentPath.startsWith(href.replace(/\/$/, ''));
}

function isCurrent(href: string) {
  return currentPath.replace(/\/$/, '') === href.replace(/\/$/, '');
}

function isNavActive(link: (typeof navLinks)[number]) {
  return isActive(link.href) || link.children?.some((child) => isActive(child.href));
}
---

<div class="header">
  <div class="title-wrapper sl-flex">
    <SiteTitle />
  </div>

  {/* Desktop nav — hidden below `lg` breakpoint (72rem) */}
  <nav class="top-nav sl-hidden lg:sl-flex print:hidden" aria-label="Primary">
    {navLinks.map((link) => (
      <div class:list={['nav-item', { 'has-dropdown': link.children }]}>
        <a
          href={link.href}
          class:list={['nav-link', { active: isNavActive(link) }]}
          aria-current={isCurrent(link.href) ? 'page' : undefined}
          aria-haspopup={link.children ? 'true' : undefined}
        >
          {link.label}
          {link.children && (
            <svg class="chevron" viewBox="0 0 12 12" width="10" height="10" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 4.5L6 7.5L9 4.5" />
            </svg>
          )}
        </a>
        {link.children && (
          <div class="dropdown">
            {link.children.map((child) => (
              <a
                href={child.href}
                class:list={['dropdown-link', { active: isActive(child.href) }]}
                aria-current={isCurrent(child.href) ? 'page' : undefined}
              >
                {child.label}
              </a>
            ))}
          </div>
        )}
      </div>
    ))}
  </nav>

  <div class="sl-flex print:hidden right-group">
    {shouldRenderSearch && <Search />}
    {/* Desktop right icons — hidden below `lg` */}
    <div class="sl-hidden lg:sl-flex right-icons">
      <div class="sl-flex social-icons">
        <SocialIcons />
      </div>
      <ThemeSelect />
      <LanguageSelect />
    </div>

    {/* Mobile hamburger — shown below `lg` */}
    <zd-nav-toggle class="zd-nav-toggle lg:sl-hidden">
      <button
        type="button"
        aria-expanded="false"
        aria-controls="zd-mobile-nav"
        aria-label="Toggle navigation menu"
        class="zd-menu-btn"
      >
        <svg class="icon-open" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="4" y1="7" x2="20" y2="7"/>
          <line x1="4" y1="12" x2="20" y2="12"/>
          <line x1="4" y1="17" x2="20" y2="17"/>
        </svg>
        <svg class="icon-close" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="6" y1="6" x2="18" y2="18"/>
          <line x1="6" y1="18" x2="18" y2="6"/>
        </svg>
      </button>
    </zd-nav-toggle>
  </div>
</div>

{/* Mobile drawer — only meaningful below `lg`; hidden via CSS otherwise */}
<div
  id="zd-mobile-nav"
  class="zd-mobile-nav lg:sl-hidden print:hidden"
  data-zd-open="false"
  aria-hidden="true"
  inert
>
  <nav aria-label="Mobile primary">
    <ul class="zd-mobile-list">
      {navLinks.map((link) => (
        <li class:list={['zd-mobile-item', { 'has-children': link.children }]}>
          {link.children ? (
            <details open={link.children.some((c) => isActive(c.href))}>
              <summary>
                <span>{link.label}</span>
                <svg class="chevron" viewBox="0 0 12 12" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M3 4.5L6 7.5L9 4.5"/>
                </svg>
              </summary>
              <ul class="zd-mobile-sublist">
                {link.children.map((child) => (
                  <li>
                    <a
                      href={child.href}
                      class:list={['zd-mobile-sublink', { active: isActive(child.href) }]}
                      aria-current={isCurrent(child.href) ? 'page' : undefined}
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          ) : (
            <a
              href={link.href}
              class:list={['zd-mobile-link', { active: isActive(link.href) }]}
              aria-current={isCurrent(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          )}
        </li>
      ))}
    </ul>
  </nav>

  <div class="zd-mobile-footer">
    <div class="zd-mobile-social">
      <SocialIcons />
    </div>
    <div class="zd-mobile-prefs">
      <ThemeSelect />
      <LanguageSelect />
    </div>
  </div>
</div>

<script>
  class ZdNavToggle extends HTMLElement {
    abortController: AbortController | undefined;

    connectedCallback() {
      const btn = this.querySelector('button');
      const drawer = document.getElementById('zd-mobile-nav');
      if (!btn || !drawer) return;
      this.abortController?.abort();
      this.abortController = new AbortController();
      const { signal } = this.abortController;

      const focusableSelector = [
        'a[href]',
        'button:not([disabled])',
        'summary',
        'select:not([disabled])',
        '[tabindex]:not([tabindex="-1"])',
      ].join(',');

      const setOpen = (open: boolean, restoreFocus = false) => {
        btn.setAttribute('aria-expanded', String(open));
        btn.setAttribute('aria-label', open ? 'Close navigation menu' : 'Open navigation menu');
        drawer.setAttribute('data-zd-open', String(open));
        drawer.setAttribute('aria-hidden', String(!open));
        drawer.toggleAttribute('inert', !open);
        document.body.toggleAttribute('data-zd-mobile-nav-open', open);
        if (open) {
          requestAnimationFrame(() => drawer.querySelector<HTMLElement>(focusableSelector)?.focus());
        } else if (restoreFocus) {
          btn.focus();
        }
      };

      btn.addEventListener('click', () => {
        const open = btn.getAttribute('aria-expanded') !== 'true';
        setOpen(open, !open);
      }, { signal });

      // Close on link click inside drawer
      drawer.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.closest('a')) setOpen(false);
      }, { signal });

      // Keep keyboard focus inside the open drawer and restore it on Escape.
      document.addEventListener('keydown', (e) => {
        if (btn.getAttribute('aria-expanded') !== 'true') return;
        if (e.key === 'Escape') {
          e.preventDefault();
          setOpen(false, true);
          return;
        }
        if (e.key !== 'Tab') return;

        const focusable = [btn, ...drawer.querySelectorAll<HTMLElement>(focusableSelector)]
          .filter((element) => !element.hasAttribute('disabled') && element.getClientRects().length > 0);
        if (!focusable.length) return;
        const first = focusable[0];
        const last = focusable.at(-1);
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last?.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }, { signal });

      // Close when resizing back to desktop (>= 72rem = 1152px)
      const mql = window.matchMedia('(min-width: 72rem)');
      mql.addEventListener('change', (e) => {
        if (e.matches) setOpen(false);
      }, { signal });

      // Starlight uses its sidebar menu below 50rem. If this drawer was opened
      // at a wider tablet width, close it before CSS hides its trigger.
      const compactSidebar = window.matchMedia('(max-width: 49.99rem)');
      compactSidebar.addEventListener('change', (e) => {
        if (e.matches && document.documentElement.hasAttribute('data-has-sidebar')) setOpen(false);
      }, { signal });
    }

    disconnectedCallback() {
      this.abortController?.abort();
    }
  }
  if (!customElements.get('zd-nav-toggle')) customElements.define('zd-nav-toggle', ZdNavToggle);
</script>

<style>
  @layer starlight.core {
    .header {
      display: flex;
      gap: var(--sl-nav-gap);
      justify-content: space-between;
      align-items: center;
      height: 100%;
      min-width: 0;
    }
    .title-wrapper {
      overflow: clip;
      padding: 0.25rem;
      margin: -0.25rem;
      min-width: 0;
      flex-shrink: 1;
    }
    .right-group,
    .right-icons,
    .social-icons {
      gap: 1rem;
      align-items: center;
    }
    .right-group {
      flex-shrink: 0;
    }
    .social-icons::after {
      content: '';
      height: 2rem;
      border-inline-end: 1px solid var(--sl-color-gray-5);
    }
    @media (min-width: 50rem) {
      :global(:root[data-has-sidebar]) {
        --__sidebar-pad: calc(2 * var(--sl-nav-pad-x));
      }
      :global(:root:not([data-has-toc])) {
        --__toc-width: 0rem;
      }
      .header {
        display: flex;
      }
    }
  }

  /* Top nav (desktop) */
  .top-nav {
    align-items: center;
    gap: 0;
    flex: 1;
    justify-content: center;
    min-width: 0;
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    padding: 0.4rem 0.7rem;
    font-size: var(--sl-text-sm);
    font-weight: 500;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    border-radius: 0.375rem;
    transition: color 0.15s, background-color 0.15s;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--sl-color-white);
    background-color: var(--sl-color-gray-5);
  }

  .nav-link.active {
    color: var(--sl-color-accent);
  }

  .chevron {
    transition: transform 0.15s;
    flex-shrink: 0;
  }

  /* Dropdown */
  .dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 12rem;
    padding: 0.4rem;
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
    z-index: 100;
  }

  .nav-item.has-dropdown:hover .dropdown,
  .nav-item.has-dropdown:focus-within .dropdown {
    display: flex;
    flex-direction: column;
  }

  .nav-item.has-dropdown:hover .chevron,
  .nav-item.has-dropdown:focus-within .chevron {
    transform: rotate(180deg);
  }

  .nav-link:focus-visible,
  .dropdown-link:focus-visible,
  .zd-menu-btn:focus-visible,
  .zd-mobile-link:focus-visible,
  .zd-mobile-sublink:focus-visible,
  .zd-mobile-item > details > summary:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
  }

  .dropdown-link {
    display: block;
    padding: 0.45rem 0.75rem;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-2);
    text-decoration: none;
    border-radius: 0.375rem;
    transition: color 0.15s, background-color 0.15s;
  }

  .dropdown-link:hover {
    color: var(--sl-color-white);
    background-color: var(--sl-color-gray-5);
  }

  .dropdown-link.active {
    color: var(--sl-color-accent);
  }

  /* Mobile hamburger button — hidden on wide screens (>= 72rem),
     visible below. Use explicit media queries instead of relying on
     Starlight's `lg:sl-hidden` utility because component-scoped styles
     are unlayered and would override the layered utility. */
  .zd-nav-toggle {
    align-items: center;
    display: none;
  }
  @media (max-width: 71.99rem) {
    .zd-nav-toggle {
      display: inline-flex;
    }
  }
  @media (max-width: 49.99rem) {
    :global(:root[data-has-sidebar]) .zd-nav-toggle {
      display: none;
    }
  }
  .zd-menu-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    padding: 0;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.375rem;
    background: transparent;
    color: var(--sl-color-white);
    cursor: pointer;
    transition: background-color 0.15s, border-color 0.15s;
  }
  .zd-menu-btn:hover {
    background-color: var(--sl-color-gray-5);
  }
  .zd-menu-btn .icon-close {
    display: none;
  }
  .zd-menu-btn[aria-expanded='true'] .icon-open {
    display: none;
  }
  .zd-menu-btn[aria-expanded='true'] .icon-close {
    display: block;
  }

  /* Mobile drawer */
  .zd-mobile-nav {
    position: fixed;
    inset-inline: 0;
    inset-block-start: var(--sl-nav-height);
    inset-block-end: 0;
    z-index: calc(var(--sl-z-index-navbar, 50) - 1);
    background-color: var(--sl-color-bg-nav, var(--sl-color-black));
    border-block-start: 1px solid var(--sl-color-hairline-shade);
    overflow-y: auto;
    padding: 1rem var(--sl-nav-pad-x, 1rem) 1.5rem;
    visibility: hidden;
    opacity: 0;
    transform: translateY(-0.5rem);
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0s linear 0.18s;
  }
  .zd-mobile-nav[data-zd-open='true'] {
    visibility: visible;
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0s linear 0s;
  }

  .zd-mobile-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .zd-mobile-link,
  .zd-mobile-item > details > summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.65rem 0.75rem;
    font-size: var(--sl-text-base);
    font-weight: 500;
    color: var(--sl-color-white);
    text-decoration: none;
    border-radius: 0.375rem;
    cursor: pointer;
    list-style: none;
  }
  .zd-mobile-item > details > summary::-webkit-details-marker { display: none; }
  .zd-mobile-link:hover,
  .zd-mobile-item > details > summary:hover {
    background-color: var(--sl-color-gray-5);
  }
  .zd-mobile-link.active {
    color: var(--sl-color-accent);
  }
  .zd-mobile-item > details[open] > summary .chevron {
    transform: rotate(180deg);
  }
  .zd-mobile-sublist {
    list-style: none;
    margin: 0.25rem 0 0.5rem;
    padding: 0 0 0 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    border-inline-start: 1px solid var(--sl-color-gray-5);
  }
  .zd-mobile-sublink {
    display: block;
    padding: 0.5rem 0.75rem;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-2);
    text-decoration: none;
    border-radius: 0.375rem;
  }
  .zd-mobile-sublink:hover {
    color: var(--sl-color-white);
    background-color: var(--sl-color-gray-5);
  }
  .zd-mobile-sublink.active {
    color: var(--sl-color-accent);
  }

  .zd-mobile-footer {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--sl-color-gray-5);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .zd-mobile-social {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .zd-mobile-prefs {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-link,
    .chevron,
    .dropdown-link,
    .zd-menu-btn,
    .zd-mobile-nav {
      transition: none;
    }
  }
</style>

<style is:global>
  /* Lock body scroll while mobile nav drawer is open */
  body[data-zd-mobile-nav-open] {
    overflow: hidden;
  }
  @media (min-width: 72rem) {
    body[data-zd-mobile-nav-open] {
      overflow: auto;
    }
  }
  @media (max-width: 49.99rem) {
    :root[data-has-sidebar] #zd-mobile-nav {
      display: none;
    }
  }
</style>

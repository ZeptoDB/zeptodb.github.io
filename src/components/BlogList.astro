---
import { getCollection } from 'astro:content';

const allDocs = await getCollection('docs');
const posts = allDocs
  .filter((e) => e.id.startsWith('blog/') && e.id !== 'blog/' && e.id !== 'blog/index')
  .map((e) => ({
    title: e.data.title,
    description: e.data.description ?? '',
    href: `/${e.id}/`,
    publishedAt: e.data.publishedAt,
  }))
  .sort((a, b) => {
    const dateOrder = (b.publishedAt?.getTime() || 0) - (a.publishedAt?.getTime() || 0);
    return dateOrder || a.title.localeCompare(b.title);
  });

const dateFormatter = new Intl.DateTimeFormat('en', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
  timeZone: 'UTC',
});
---

<div class="blog-grid">
  {posts.map((p) => (
    <article class="blog-card">
      <a href={p.href}>
        {p.publishedAt && (
          <time datetime={p.publishedAt.toISOString()}>{dateFormatter.format(p.publishedAt)}</time>
        )}
        <h3>{p.title}</h3>
        <p>{p.description}</p>
        <span class="read-more">Read article</span>
      </a>
    </article>
  ))}
</div>

<style>
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    margin: 1.5rem 0;
  }
  .blog-card {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s;
  }
  .blog-card > a {
    display: block;
    height: 100%;
    padding: 1.2rem;
    text-decoration: none;
    color: inherit;
  }
  .blog-card:hover {
    border-color: var(--sl-color-accent);
    transform: translateY(-2px);
  }
  .blog-card h3 {
    margin: 0.35rem 0 0.5rem;
    font-size: 1.05rem;
    color: var(--sl-color-white);
  }
  .blog-card p {
    margin: 0 0 0.75rem;
    font-size: 0.85rem;
    opacity: 0.8;
    line-height: 1.5;
  }
  .read-more {
    font-size: 0.8rem;
    color: var(--sl-color-accent);
    font-weight: 500;
  }
  time {
    color: var(--sl-color-gray-2);
    font-family: var(--sl-font-mono);
    font-size: var(--sl-text-xs);
  }
</style>

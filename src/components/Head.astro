---
import socialPreviews from '../generated/social-previews.json';

interface SocialPreview {
  image: string;
  alt: string;
  width: number;
  height: number;
}

const siteUrl = 'https://zeptodb.com';
const description =
  'ZeptoDB is an Action-Outcome Memory database for Physical AI and robotic agents, connecting robot telemetry, prior actions, outcomes, and replayable evidence.';
const keywords = [
  'Action-Outcome Memory',
  'Physical AI memory',
  'robot action memory',
  'robot safety replay',
  'robotics database',
  'ROS 2 database',
  'agent memory database',
  'AI agent memory',
  'time-series database',
  'AgentOps telemetry',
  'prompt cache',
  'context retrieval',
  'microsecond database',
  'zero-copy Python',
].join(', ');
const pathname = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const routeData = Astro.locals.starlightRoute;
const pageData = routeData.entry.data;
const pageTitle = pageData.title;
const pageDescription = pageData.description || description;
const pageUrl = new URL(Astro.url.pathname, siteUrl).href;
const isBlogPost = /^\/blog\/[^/]+\/$/.test(pathname);
const isResearchPage = pathname.startsWith('/research/');
const isExperimentPage = pathname.startsWith('/experiments/');
const isExperimentIndex = pathname === '/experiments/';
const ogType = isBlogPost || isResearchPage || isExperimentPage ? 'article' : 'website';
const publishedAt = pageData.publishedAt?.toISOString();
const socialPreviewIndex = socialPreviews as Record<string, SocialPreview>;
const socialPreview = socialPreviewIndex[pathname] || socialPreviewIndex[decodeURIComponent(pathname)];
const ogImage = new URL(socialPreview?.image || '/og-default.png', Astro.site);
const ogImageAlt = socialPreview?.alt || 'ZeptoDB: Action-Outcome Memory for Physical AI';
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID?.trim();
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION?.trim();
const bingSiteVerification = import.meta.env.PUBLIC_BING_SITE_VERIFICATION?.trim();

const graph: Record<string, unknown>[] = [
  {
    '@type': 'Organization',
    '@id': `${siteUrl}/#organization`,
    name: 'ZeptoDB',
    url: siteUrl,
    sameAs: [
      'https://github.com/zeptodb/zeptodb',
      'https://twitter.com/zeptodb',
      'https://discord.gg/PAtzvCa7',
    ],
  },
  {
    '@type': 'WebSite',
    '@id': `${siteUrl}/#website`,
    name: 'ZeptoDB',
    url: siteUrl,
    description,
    inLanguage: 'en',
    publisher: { '@id': `${siteUrl}/#organization` },
  },
];

if (pathname === '/') {
  graph.push({
    '@type': 'SoftwareApplication',
    '@id': `${siteUrl}/#software`,
    name: 'ZeptoDB',
    url: siteUrl,
    applicationCategory: 'Database',
    applicationSubCategory: 'Physical AI action-outcome memory database',
    operatingSystem: 'Linux',
    description,
    keywords,
    featureList: [
      'Action-Outcome Memory for Physical AI',
      'ROS 2 telemetry ingest and replay',
      'Robot action and outcome evidence replay',
      'Agent Memory with tenant-scoped recall',
      'Microsecond time-series queries',
      'Zero-copy Python integration',
    ],
    publisher: { '@id': `${siteUrl}/#organization` },
  });
} else if (isExperimentIndex) {
  graph.push({
    '@type': 'CollectionPage',
    '@id': `${pageUrl}#collection`,
    name: pageTitle,
    description: pageDescription,
    url: pageUrl,
    isPartOf: { '@id': `${siteUrl}/#website` },
    inLanguage: 'en',
  });
} else if (isBlogPost || isResearchPage || isExperimentPage) {
  graph.push({
    '@type': isBlogPost ? 'BlogPosting' : 'TechArticle',
    '@id': `${pageUrl}#article`,
    headline: pageTitle,
    description: pageDescription,
    url: pageUrl,
    mainEntityOfPage: pageUrl,
    inLanguage: 'en',
    ...(publishedAt ? { datePublished: publishedAt, dateModified: publishedAt } : {}),
    author: { '@id': `${siteUrl}/#organization` },
    publisher: { '@id': `${siteUrl}/#organization` },
  });
} else {
  graph.push({
    '@type': 'WebPage',
    '@id': `${pageUrl}#webpage`,
    name: pageTitle,
    description: pageDescription,
    url: pageUrl,
    isPartOf: { '@id': `${siteUrl}/#website` },
    inLanguage: 'en',
  });
}

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': graph,
});

const resolvedHead = routeData.head.map((item) => {
  if (item.tag !== 'meta' || item.attrs?.property !== 'og:type') return item;
  return { ...item, attrs: { ...item.attrs, content: ogType } };
});
---

{!import.meta.env.DEV && (
  <meta
    http-equiv="Content-Security-Policy"
    content="default-src 'self'; base-uri 'self'; object-src 'none'; form-action 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com https://region1.google-analytics.com https://analytics.google.com; worker-src 'self' blob:; frame-src 'none'"
  />
)}
{resolvedHead.map(({ tag: Tag, attrs, content }) => <Tag {...attrs} set:html={content} />)}

<!-- Starlight already handles og:title, og:description, og:url, og:type, twitter:card, meta description -->
<!-- We add only what's missing: images and structured data -->
<meta name="referrer" content="strict-origin-when-cross-origin" />
<meta name="keywords" content={keywords} />
<meta name="theme-color" content="#0a0e17" />
<meta property="og:image" content={ogImage.href} />
<meta property="og:image:width" content={String(socialPreview?.width || 1200)} />
<meta property="og:image:height" content={String(socialPreview?.height || 630)} />
<meta property="og:image:alt" content={ogImageAlt} />
<meta name="twitter:image" content={ogImage.href} />
<meta name="twitter:image:alt" content={ogImageAlt} />
{googleSiteVerification && <meta name="google-site-verification" content={googleSiteVerification} />}
{bingSiteVerification && <meta name="msvalidate.01" content={bingSiteVerification} />}
<script is:inline type="application/ld+json" set:html={jsonLd} />

{gaMeasurementId && (
  <>
    <script is:inline define:vars={{ gaMeasurementId }}>
      (() => {
        if (window.__zeptoAnalyticsBound) return;
        window.__zeptoAnalyticsBound = true;

        const campaignKeys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term'];
        const storageKey = 'zeptodb_campaign_context';

        function contentGroup(pathname) {
          if (pathname === '/') return 'home';
          if (pathname.startsWith('/experiments/')) return 'experiments';
          if (pathname.startsWith('/research/')) return 'research';
          if (pathname.startsWith('/use-cases/')) return 'use_case';
          if (pathname.startsWith('/benchmarks/')) return 'benchmark';
          if (pathname.startsWith('/compare/')) return 'comparison';
          if (pathname.startsWith('/blog/')) return 'blog';
          if (pathname.startsWith('/community/')) return 'community';
          if (/^\/(features|integrations|security)\//.test(pathname)) return 'product_education';
          if (pathname.startsWith('/about/')) return 'about';
          if (/^\/(docs|getting-started|api|deployment|operations|feeds)\//.test(pathname)) return 'documentation';
          return 'project';
        }

        function campaignContext() {
          const params = new URLSearchParams(window.location.search);
          const current = {};
          for (const key of campaignKeys) {
            const value = params.get(key);
            if (value) current[key] = value.slice(0, 100);
          }

          try {
            if (Object.keys(current).length) {
              window.sessionStorage.setItem(storageKey, JSON.stringify(current));
              return current;
            }
            return JSON.parse(window.sessionStorage.getItem(storageKey) || '{}');
          } catch {
            return current;
          }
        }

        function cleanText(value, fallback = '') {
          return String(value || fallback).replace(/\s+/g, ' ').trim().slice(0, 100);
        }

        function navigationArea(element) {
          if (element.closest('#zd-mobile-nav')) return 'mobile_navigation';
          if (element.closest('.top-nav')) return 'primary_navigation';
          if (element.closest('aside, .sidebar-pane')) return 'sidebar';
          if (element.closest('footer')) return 'footer';
          if (element.closest('header, .header')) return 'header';
          return 'content';
        }

        function internalDestination(pathname) {
          if (pathname.startsWith('/experiments/')) return 'experiment';
          if (pathname.startsWith('/research/')) return 'research';
          if (pathname.startsWith('/use-cases/action-outcome-memory/')) return 'action_outcome';
          if (pathname.includes('quick_start') || pathname.includes('quickstart')) return 'quickstart';
          if (pathname.startsWith('/benchmarks/')) return 'benchmark';
          if (pathname.startsWith('/use-cases/')) return 'use_case';
          if (pathname.startsWith('/compare/')) return 'comparison';
          if (pathname.startsWith('/blog/')) return 'blog';
          if (/^\/(docs|getting-started|api|deployment|operations|feeds)\//.test(pathname)) return 'documentation';
          if (pathname.startsWith('/community/')) return 'community';
          return 'internal';
        }

        function eventForDestination(destination) {
          return {
            research: 'research_click',
            experiment: 'experiment_click',
            action_outcome: 'action_outcome_click',
            quickstart: 'quickstart_click',
            benchmark: 'benchmark_click',
            use_case: 'use_case_click',
            comparison: 'comparison_click',
            blog: 'blog_click',
            documentation: 'docs_click',
            community: 'community_click',
          }[destination] || 'internal_link_click';
        }

        const baseContext = () => ({
          page_path: window.location.pathname,
          page_title: document.title.slice(0, 100),
          content_group: contentGroup(window.location.pathname),
          ...campaignContext(),
        });

        const productionHosts = new Set(['zeptodb.com', 'www.zeptodb.com', 'zeptodb.github.io']);
        const shouldTransmit = productionHosts.has(window.location.hostname);
        window.dataLayer = window.dataLayer || [];
        function gtag() {
          window.dataLayer.push(arguments);
        }
        window.gtag = window.gtag || gtag;
        if (shouldTransmit && !document.querySelector('script[data-zeptodb-ga]')) {
          const loader = document.createElement('script');
          loader.async = true;
          loader.src = `https://www.googletagmanager.com/gtag/js?id=${encodeURIComponent(gaMeasurementId)}`;
          loader.dataset.zeptodbGa = 'true';
          document.head.appendChild(loader);
        }
        window.gtag('js', new Date());
        window.gtag('config', gaMeasurementId, {
          send_page_view: true,
          ...baseContext(),
        });
        document.documentElement.dataset.analyticsReady = 'true';
        document.documentElement.dataset.analyticsMode = shouldTransmit ? 'production' : 'preview';

        function sendGaEvent(name, params = {}) {
          if (typeof window.gtag !== 'function') return;
          document.documentElement.dataset.analyticsLastEvent = name;
          window.gtag('event', name, { ...baseContext(), ...params });
        }
        window.zeptoAnalytics = { track: sendGaEvent };

        function currentSearchTerm() {
          const input = document.querySelector('#starlight__search .pagefind-ui__search-input');
          return input instanceof HTMLInputElement ? cleanText(input.value).slice(0, 100) : '';
        }

        document.addEventListener('click', (event) => {
          const target = event.target instanceof Element ? event.target : null;
          if (!target) return;

          const searchOpenButton = target.closest('site-search button[data-open-modal]');
          if (searchOpenButton) {
            sendGaEvent('search_open', { interaction_method: 'button' });
          }

          const copyButton = target.closest('button');
          const copyLabel = cleanText(
            copyButton?.getAttribute('aria-label'),
            copyButton?.textContent,
          ).toLowerCase();
          const isCodeCopy = copyButton && (
            copyLabel.includes('copy') ||
            copyButton.closest('.copy') !== null
          );
          if (isCodeCopy) {
            sendGaEvent('code_copy', {
              nav_area: navigationArea(copyButton),
              code_language: copyButton.closest('figure, pre')?.querySelector('[data-language]')?.getAttribute('data-language') || 'unknown',
            });
          }

          const link = target.closest('a[href]');
          if (!link) return;
          const href = link.getAttribute('href');
          if (!href || href.startsWith('#')) return;

          let url;
          try {
            url = new URL(href, window.location.href);
          } catch {
            return;
          }

          if (!['http:', 'https:'].includes(url.protocol)) return;

          if (link.closest('#starlight__search')) {
            const searchLinks = [...document.querySelectorAll('#starlight__search a[href]')];
            sendGaEvent('search_result_click', {
              search_term: currentSearchTerm(),
              result_position: Math.max(1, searchLinks.indexOf(link) + 1),
              result_url: url.href.slice(0, 500),
            });
          }

          const linkContext = {
            link_url: url.href.slice(0, 500),
            link_text: cleanText(link.textContent, link.getAttribute('aria-label')),
            link_domain: url.hostname,
            destination_path: url.pathname,
            nav_area: navigationArea(link),
          };

          if (link.matches('[data-experiment-link]')) {
            sendGaEvent('experiment_record_open', {
              ...linkContext,
              experiment_id: cleanText(link.getAttribute('data-experiment-id'), 'unknown'),
            });
          }

          if (link.matches('[data-raw-evidence-link]')) {
            sendGaEvent('raw_evidence_open', linkContext);
          }

          if (url.origin === window.location.origin) {
            const destination = internalDestination(url.pathname);
            sendGaEvent(eventForDestination(destination), {
              ...linkContext,
              destination_group: destination,
            });
            return;
          }

          if (url.hostname === 'github.com' || url.hostname.endsWith('.github.com')) {
            const githubTarget = url.pathname.includes('/issues')
              ? 'issue'
              : url.pathname.includes('/discussions')
                ? 'discussion'
                : url.pathname.includes('/stargazers')
                  ? 'stargazers'
                  : 'repository';
            sendGaEvent('github_click', { ...linkContext, github_target: githubTarget });
            return;
          }

          if (url.hostname.includes('discord.gg') || url.hostname.includes('discord.com')) {
            sendGaEvent('community_click', { ...linkContext, community_platform: 'discord' });
            return;
          }

          if (['x.com', 'twitter.com', 'threads.net', 'linkedin.com', 'reddit.com'].some((domain) => url.hostname.endsWith(domain))) {
            sendGaEvent('social_click', { ...linkContext, social_platform: url.hostname.replace(/^www\./, '') });
            return;
          }

          sendGaEvent('outbound_click', linkContext);
        }, { capture: true });

        let searchTimer;
        let lastSearchTerm = '';
        document.addEventListener('input', (event) => {
          const input = event.target;
          if (!(input instanceof HTMLInputElement) || !input.matches('#starlight__search .pagefind-ui__search-input')) return;
          window.clearTimeout(searchTimer);
          const searchTerm = cleanText(input.value).slice(0, 100);
          if (searchTerm.length < 2 || searchTerm === lastSearchTerm) return;
          searchTimer = window.setTimeout(() => {
            lastSearchTerm = searchTerm;
            const resultCount = document.querySelectorAll('#starlight__search .pagefind-ui__result').length;
            sendGaEvent('view_search_results', {
              search_term: searchTerm,
              visible_result_count: resultCount,
            });
          }, 900);
        });

        window.addEventListener('keydown', (event) => {
          if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'k') {
            sendGaEvent('search_open', { interaction_method: 'keyboard' });
          }
        });

        const scrollThresholds = [25, 50, 75, 90];
        const sentThresholds = new Set();
        let scrollTicking = false;
        function measureScrollDepth() {
          scrollTicking = false;
          const scrollable = document.documentElement.scrollHeight - window.innerHeight;
          if (scrollable <= 0) return;
          const percent = Math.min(100, Math.round((window.scrollY / scrollable) * 100));
          for (const threshold of scrollThresholds) {
            if (percent >= threshold && !sentThresholds.has(threshold)) {
              sentThresholds.add(threshold);
              sendGaEvent('scroll_depth', { percent_scrolled: threshold });
            }
          }
        }
        window.addEventListener('scroll', () => {
          if (scrollTicking) return;
          scrollTicking = true;
          window.requestAnimationFrame(measureScrollDepth);
        }, { passive: true });
      })();
    </script>
  </>
)}

{
  "name": "zeptodb-site",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "sync-docs": "node scripts/sync-docs.mjs",
    "prepare:site": "node scripts/sync-docs.mjs && node scripts/growth-social-assets.mjs",
    "dev": "pnpm prepare:site && astro dev",
    "build": "pnpm prepare:site && ASTRO_TELEMETRY_DISABLED=1 astro build",
    "check": "astro check",
    "qa:site": "node scripts/qa-site.mjs",
    "qa": "pnpm build && pnpm check && pnpm qa:site && pnpm growth:validate",
    "preview": "astro preview",
    "astro": "astro",
    "growth:validate": "node scripts/growth-validate.mjs",
    "growth:links": "node scripts/growth-build-links.mjs",
    "growth:social-assets": "node scripts/growth-social-assets.mjs",
    "growth:search": "node scripts/growth-search-queue.mjs",
    "growth:score": "node scripts/growth-score-opportunities.mjs",
    "growth:ai-search": "node scripts/growth-ai-search-measure.mjs",
    "growth:answer-page": "node scripts/growth-answer-page.mjs"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/starlight": "^0.38.5",
    "astro": "^6.4.8",
    "esbuild": "^0.28.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.28.1",
      "js-yaml": "4.2.0",
      "postcss": "8.5.10"
    }
  }
}

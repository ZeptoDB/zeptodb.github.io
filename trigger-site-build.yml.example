# Place this file in ZeptoDB/ZeptoDB repo at .github/workflows/trigger-site-build.yml
# When docs/ changes are pushed, triggers the zeptodb.github.io rebuild
name: Trigger Site Build

on:
  push:
    branches: [main]
    paths:
      - 'docs/**'

jobs:
  trigger:
    runs-on: ubuntu-latest
    steps:
      - name: Trigger ZeptoDB site rebuild
        uses: peter-evans/repository-dispatch@v4
        with:
          token: ${{ secrets.SITE_DEPLOY_TOKEN }}
          repository: ZeptoDB/zeptodb.github.io
          event-type: docs-updated
          client-payload: '{"source_sha":"${{ github.sha }}","source_ref":"${{ github.ref_name }}"}'
